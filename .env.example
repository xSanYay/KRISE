# LLM Provider
# Supported: auto, bedrock, gemini, anthropic
LLM_PROVIDER=auto

# AWS Bedrock Configuration
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=
BEDROCK_MODEL_ID=

# Google Gemini Configuration
GEMINI_API_KEY=
GEMINI_MODEL_ID=gemini-2.5-flash
# Dedicated Gemini model for casual/small-talk turns
GEMINI_SMALL_TALK_MODEL_ID=gemini-3.1-flash-lite-preview
GEMINI_SMALL_TALK_TEMPERATURE=0.4
GEMINI_SMALL_TALK_THINKING_LEVEL=MINIMAL
# Keep disabled by default for lower latency/cost; can be enabled later if needed
GEMINI_ENABLE_GOOGLE_SEARCH=false
SMALL_TALK_ENABLED=true
SMALL_TALK_MIN_CHARS=1

# Anthropic Configuration
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_ID=claude-sonnet-4-20250514

# App Configuration
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# Frontend / CORS
FRONTEND_URL=http://localhost:5173
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:3000
CORS_ALLOW_ORIGIN_REGEX='^https://.*\.app\.github\.dev$'

# Frontend Dev Server Overrides
VITE_ALLOWED_HOSTS=localhost,127.0.0.1,.app.github.dev,.github.dev
VITE_BACKEND_HTTP_URL=
VITE_BACKEND_WS_URL=

# Scraping
SCRAPING_DELAY_MIN=1.0
SCRAPING_DELAY_MAX=3.0
SCRAPING_MAX_PRODUCTS=15

# Conversation / Agent thresholds
CONVICTION_THRESHOLD=0.80
MAX_SOCRATIC_TURNS=5
DECISION_MAX_TURNS=10
DECISION_MIN_TURNS_BEFORE_CONCLUSION=3
DECISION_CONCLUSION_THRESHOLD=0.85