# LLM Provider
# Supported: auto, bedrock, gemini, anthropic
LLM_PROVIDER=auto

# AWS Bedrock Configuration
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=
BEDROCK_MODEL_ID=

# Google Gemini Configuration
GEMINI_API_KEY=
GEMINI_MODEL_ID=gemini-2.5-flash

# Anthropic Configuration
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_ID=claude-sonnet-4-20250514

# App Configuration
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# Frontend / CORS
FRONTEND_URL=http://localhost:5173
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:3000
CORS_ALLOW_ORIGIN_REGEX='^https://.*\.app\.github\.dev$'

# Frontend Dev Server Overrides
VITE_ALLOWED_HOSTS=localhost,127.0.0.1,.app.github.dev,.github.dev
VITE_BACKEND_HTTP_URL=
VITE_BACKEND_WS_URL=

# Scraping
SCRAPING_DELAY_MIN=1.0
SCRAPING_DELAY_MAX=3.0
SCRAPING_MAX_PRODUCTS=15

# Conversation / Agent thresholds
CONVICTION_THRESHOLD=0.80
MAX_SOCRATIC_TURNS=5